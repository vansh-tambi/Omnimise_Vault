# Database
MONGO_URI=paste-your-mongodb-atlas-connection-string-here

# Authentication
JWT_SECRET=paste-your-openssl-output-here
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# Google OAuth (get from Cloud Console → Credentials, no billing needed)
GOOGLE_CLIENT_ID=paste-your-client-id-here
GOOGLE_CLIENT_SECRET=paste-your-client-secret-here

# Google Cloud Storage (fill these once billing activates)
GCS_ENABLED=false
GCS_BUCKET_NAME=leave-blank-for-now
GCS_SERVICE_ACCOUNT_JSON=./service-account.json

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# DigiLocker (fill once developer portal approves your app)
DIGILOCKER_CLIENT_ID=leave-blank-for-now
DIGILOCKER_CLIENT_SECRET=leave-blank-for-now
